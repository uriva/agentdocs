{
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.10",
    "@std/": "jsr:@std/",
    "zod": "npm:zod@^3.23.0"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read main.ts",
    "start": "deno run --allow-net --allow-env --allow-read main.ts",
    "generate-docs": "deno run --allow-write --allow-read generate-docs.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "dom", "dom.iterable"]
  },
  "deploy": {
    "org": "uriva",
    "app": "agentdocs-api"
  }
}






